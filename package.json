{
  "name": "block-miner",
  "version": "1.0.0",
  "description": "Web3 mining simulation game in Node.js",
  "main": "server/server.js",
  "scripts": {
    "dev": "nodemon server/server.js",
    "start": "node server/server.js",
    "build:client": "npm run build --prefix client",
    "build:client:local": "npx cross-env VITE_BLOCKMINER_ORIGIN=http://localhost:3000 npm run build --prefix client",
    "build:client:local:3001": "npx cross-env VITE_BLOCKMINER_ORIGIN=http://localhost:3001 npm run build --prefix client",
    "free:3000": "npx --yes kill-port 3000",
    "start:server:prod": "npx cross-env NODE_ENV=production node server/server.js",
    "start:prod": "npm run build:client:local && npx cross-env NODE_ENV=production node server/server.js",
    "start:prod:3001": "npm run build:client:local:3001 && npx cross-env NODE_ENV=production PORT=3001 node server/server.js",
    "deploy": "python deploy.py",
    "deploy:app": "python deploy.py",
    "deploy:app:nocache": "python deploy.py --no-cache",
    "db:generate": "prisma generate --schema=server/prisma/schema.prisma",
    "db:push": "prisma db push --schema=server/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=server/prisma/schema.prisma",
    "test": "node scripts/run-node-tests.mjs",
    "test:security": "npx cross-env JWT_SECRET=testsecret node --test tests/security.webhooks.test.js",
    "contracts:test": "npm test --prefix contracts",
    "test:offer-events": "node --test tests/offerEvents.helpers.test.mjs tests/offerEvents.listQuery.test.mjs tests/offerEvents.publicList.test.mjs",
    "test:read-earn": "npx cross-env JWT_SECRET=testsecret node --test tests/readEarn.isLive.test.mjs tests/readEarnSchemas.test.mjs",
    "test:mini-pass": "node --test tests/miniPass.levelMath.test.mjs tests/miniPass.i18n.test.mjs tests/miniPass.adminValidation.test.mjs",
    "lint": "eslint . --ext .js",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "backup": "node scripts/backup.js",
    "fix:miner-images": "node scripts/fixDuplicateMinerImageUrls.js",
    "install-hooks": "git config core.hooksPath .githooks || true"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^8.0.3",
    "otplib": "^12.0.1",
    "pg": "^8.19.0",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0",
    "zod": "^3.25.2"
  },
  "devDependencies": {
    "@csstools/css-parser-algorithms": "4.0.0",
    "@csstools/css-tokenizer": "4.0.0",
    "@noble/hashes": "2.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.36.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.6.2",
    "prisma": "^7.4.2",
    "vitest": "^4.1.0"
  },
  "prisma": {
    "seed": "node server/prisma/seed.js"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "tar": "^7.5.8"
  }
}
