# Copia para deploy.secrets.local (na raiz do repo) e preenche.
# deploy.secrets.local está no .gitignore — NUNCA commites.

SSH_HOST=89.167.119.164
SSH_USER=root
SSH_PASSWORD=your_ssh_password_here
REMOTE_PATH=/root/block-miner

# Opcional: quando o PuTTY diz "host key does not match", cola a linha "SHA256:..." que o plink mostra:
# SSH_HOSTKEY=SHA256:...

# Opcional: após git pull, copia certificados Let's Encrypt já emitidos na VM para nginx/certs
# (evita ERR_CERT_AUTHORITY_INVALID quando o reset traz PEM de desenvolvimento fora do repo).
# LE_SYNC_DOMAIN=tests.blockminer.space
