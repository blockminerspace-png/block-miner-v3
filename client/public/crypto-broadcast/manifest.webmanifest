{
  "name": "BlockMiner Crypto Live Dashboard",
  "short_name": "BM Crypto",
  "description": "Live crypto dashboard for broadcast / kiosk capture.",
  "start_url": "/crypto-broadcast/",
  "scope": "/crypto-broadcast/",
  "display": "fullscreen",
  "display_override": ["fullscreen", "standalone", "minimal-ui"],
