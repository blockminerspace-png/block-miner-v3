# Vite client — copy to client/.env for local dev (`npm run dev` in client/)
# Production: same variables are passed at Docker image build (see root .env.example + docker-compose build args).

VITE_DISCORD_URL=
VITE_TELEGRAM_URL=
# Optional footer links on the landing page (omit to hide the icon)
VITE_TWITTER_URL=
VITE_YOUTUBE_URL=

# Optional: embed this video on /liveserver. If empty, the app tries ?v= from VITE_YOUTUBE_URL, else a default ID.
# VITE_LIVE_SERVER_YOUTUBE_ID=

# Google Analytics 4 (gtag) — also used by landing custom events (scroll depth, CTA clicks)
# VITE_GA_ID=G-xxxxxxxxxx
# Consent Mode v2: set to 1 to default analytics_storage denied until you call gtag('consent','update',...) in UI
# VITE_GTAG_CONSENT_STRICT=

# Meta (Facebook) Pixel — optional conversion tracking on the landing page
# VITE_META_PIXEL_ID=
